{
  "name": "wave-roll-piano",
  "displayName": "WaveRoll Piano - MIDI Editor",
  "description": "MIDI piano roll editor with playback, MIDI-TSV conversion, and piano sound selection",
  "publisher": "crescent-stdio",
  "version": "0.5.0",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/crescent-stdio/wave-roll-studio"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "music",
    "midi",
    "piano-roll",
    "midi-editor",
    "midi-tsv",
    "midi-visualisation",
    "audio",
    "visualization",
    "piano"
  ],
  "main": "./dist/extension/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "wave-roll-piano.preview",
        "displayName": "WaveRoll Piano",
        "selector": [
          {
            "filenamePattern": "*.mid"
          },
          {
            "filenamePattern": "*.midi"
          },
          {
            "filenamePattern": "*.mid.tsv"
          },
          {
            "filenamePattern": "*.midi.tsv"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "wave-roll-piano.exportMidiTsv",
        "title": "WaveRoll Piano: Export MIDI as TSV"
      },
      {
        "command": "wave-roll-piano.exportTsvMidi",
        "title": "WaveRoll Piano: Export MIDI-TSV as MIDI"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "wave-roll-piano.exportMidiTsv",
          "when": "resourceExtname == .mid || resourceExtname == .midi",
          "group": "navigation@20"
        },
        {
          "command": "wave-roll-piano.exportTsvMidi",
          "when": "resourceFilename =~ /\\.midi?\\.tsv$/",
          "group": "navigation@21"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "vsce package",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.20.0",
    "typescript": "^5.0.0",
    "vite": "^7.2.6"
  },
  "dependencies": {
    "@tonejs/midi": "^2.0.28",
    "midi-file": "1.2.4",
    "tone": "^15.1.22",
    "wave-roll": "0.4.0"
  }
}
